{
  "expo": {
    "name": "ironlog",
    "slug": "ironlog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ironlog.disciplineapp",
      "storeKitConfiguration": "./Products.storekit",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.16941655300-bbsik1d00uh3ono8hidqadhb6fvs7hkt"
            ]
          }
        ]
      },
      "config": {
        "googleSignIn": {
          "reservedClientId": "16941655300-bbsik1d00uh3ono8hidqadhb6fvs7hkt.apps.googleusercontent.com"
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      "expo-notifications",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "0a6046bc-725a-49d1-8d62-d41565c571b4"
      }
    }
  }
}
